FROM mcr.microsoft.com/devcontainers/python:1-3.11-bookworm

# The MS devcontainer image ships a stale Yarn apt source whose GPG key
# expired; apt-get update fails on it. Drop that source before installing.
RUN rm -f /etc/apt/sources.list.d/yarn.list

# Minimal apt deps for the verification phase. Heavier tooling for scenarios
# (build-essential, libcurl-dev, libssl-dev, libbz2-dev, liblzma-dev, zlib1g-dev,
# tabix, bcftools — needed for cyvcf2 + scispaCy compile) gets added back when
# scenarios A and B are built. Keeping this slim now keeps the Codespace under
# the 32GB disk ceiling.
RUN apt-get update && apt-get install -y --no-install-recommends \
        curl \
        jq \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspaces

CMD ["sleep", "infinity"]
