FROM mcr.microsoft.com/devcontainers/python:1-3.11-bookworm

# The MS devcontainer image ships a stale Yarn apt source whose GPG key
# expired; apt-get update fails on it. Drop that source before installing.
RUN rm -f /etc/apt/sources.list.d/yarn.list

# System packages needed for cyvcf2, scispacy, and friends
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        libcurl4-openssl-dev \
        libssl-dev \
        liblzma-dev \
        libbz2-dev \
        zlib1g-dev \
        tabix \
        bcftools \
        jq \
        curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspaces

# requirements.txt is copied AT BUILD TIME by Codespaces from the repo root, but the
# devcontainer build context is .devcontainer/, so we install lazily from
# onCreateCommand.sh which runs after the workspace is mounted.

CMD ["sleep", "infinity"]
